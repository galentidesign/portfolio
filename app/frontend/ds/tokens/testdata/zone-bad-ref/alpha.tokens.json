{
  "meta": {
    "name": "alpha",
    "label": "Alpha",
    "era": "test",
    "colorScheme": "light",
    "default": true,
    "hidden": false,
    "description": "Alpha — zone value references a raw key that does not exist",
    "fonts": []
  },
  "raw": { "color": { "white": "#fff", "black": "#000" } },
  "semantic": {
    "color": { "surface": "{raw.color.white}", "ink": "{raw.color.black}" },
    "radius": { "control": "4px" },
    "type": { "body-size": "1rem" },
    "density": { "gap": "var(--space-1)" },
    "motion": { "duration-xs": "90ms" },
    "shadow": { "raised": "none" }
  },
  "zones": {
    "night": {
      "colorScheme": "dark",
      "tokens": {
        "color": { "surface": "{raw.color.void}" }
      }
    }
  }
}
